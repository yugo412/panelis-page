{
  "name": "panelis-php/page",
  "description": "Manage static pages and informational content such as about, terms, privacy policy, and other public-facing pages.",
  "license": "MIT",
  "keywords": [
    "panelis"
  ],
  "require": {
    "filament/filament": "^5.0",
    "laravel/framework": "^13.0"
  },
  "autoload": {
    "psr-4": {
      "Panelis\\Page\\": "src/",
      "Panelis\\Page\\Database\\Factories\\": "database/factories/",
      "Panelis\\Page\\Database\\Seeders\\": "database/seeders/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "Panelis\\Page\\Tests\\": "tests/"
    }
  },
  "extra": {
    "laravel": {
      "providers": [
        "Panelis\\Page\\Providers\\PageServiceProvider"
      ]
    }
  },
  "require-dev": {
    "laravel/pint": "^1.29"
  }
}
